    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^28.1.0",
