generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum UserRole {
  admin
  captain
  vice_captain
  squad_captain
  member
}

enum MemberType {
  senior_competitive
  student
  recreational
}

enum BoatClassification {
  black
  green
}

enum BoatStatus {
  available
  not_in_use
}

enum BoatCategory {
  club
  private
  syndicate
  tinny
}

enum EquipmentType {
  erg
  bike
  gym
}

enum ResourceType {
  boat
  equipment
  oar_set
}

enum ApplicationStatus {
  pending
  approved
  denied
}

// ─── Squads ─────────────────────────────────────────────────────

model Squad {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  boats      Boat[]
  userSquads UserSquad[]

  @@map("squads")
}

// ─── Users ──────────────────────────────────────────────────────

model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  fullName                String     @map("full_name")
  role                    UserRole   @default(member)
  memberType              MemberType @default(recreational) @map("member_type")
  weightKg                Decimal?   @map("weight_kg") @db.Decimal(5, 1)
  hasBlackBoatEligibility Boolean    @default(false) @map("has_black_boat_eligibility")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")

  squads               UserSquad[]
  ownedBoats           Boat[]                 @relation("BoatOwner")
  bookings             Booking[]
  blackBoatApplications BlackBoatApplication[] @relation("Applicant")
  reviewedApplications  BlackBoatApplication[] @relation("Reviewer")
  sentInvitations      Invitation[]           @relation("Inviter")
  auditLogs            AuditLog[]

  @@map("users")
}

model UserSquad {
  userId  String @map("user_id")
  squadId String @map("squad_id")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@id([userId, squadId])
  @@map("user_squads")
}

// ─── Boats ──────────────────────────────────────────────────────

model Boat {
  id                 String             @id @default(uuid())
  name               String
  boatType           String             @map("boat_type") // e.g. "8+", "4x/4-", "1x"
  category           BoatCategory       @default(club)
  classification     BoatClassification @default(green)
  status             BoatStatus         @default(available)
  avgWeightKg        Decimal?           @map("avg_weight_kg") @db.Decimal(5, 1)
  isOutside          Boolean            @default(false) @map("is_outside")
  responsibleSquadId String?            @map("responsible_squad_id")
  responsiblePerson  String?            @map("responsible_person")
  ownerUserId        String?            @map("owner_user_id")
  displayOrder       Int                @default(0) @map("display_order")
  notes              String?

  createdAt DateTime @default(now()) @map("created_at")

  responsibleSquad Squad? @relation(fields: [responsibleSquadId], references: [id])
  owner            User?  @relation("BoatOwner", fields: [ownerUserId], references: [id])
  bookings         Booking[]

  @@map("boats")
}

// ─── Equipment ──────────────────────────────────────────────────

model Equipment {
  id     String        @id @default(uuid())
  type   EquipmentType
  number Int

  bookings Booking[]

  @@unique([type, number])
  @@map("equipment")
}

// ─── Oar Sets ───────────────────────────────────────────────────

model OarSet {
  id   String @id @default(uuid())
  name String @unique // "Set A" through "Set F"

  bookings Booking[]

  @@map("oar_sets")
}

// ─── Time Slots ─────────────────────────────────────────────────

model TimeSlot {
  id         String  @id @default(uuid())
  slotNumber Int     @map("slot_number")
  label      String
  startTime  String? @map("start_time") // stored as "05:00" etc.
  endTime    String? @map("end_time")
  isWeekend  Boolean @default(false) @map("is_weekend")

  @@unique([slotNumber, isWeekend])
  @@map("time_slots")
}

// ─── Bookings ───────────────────────────────────────────────────

model Booking {
  id             String       @id @default(uuid())
  date           DateTime     @db.Date
  resourceType   ResourceType @map("resource_type")
  boatId         String?      @map("boat_id")
  equipmentId    String?      @map("equipment_id")
  oarSetId       String?      @map("oar_set_id")
  userId         String       @map("user_id")
  bookerName     String       @map("booker_name")
  crewCount      Int          @default(1) @map("crew_count")
  startSlot      Int          @map("start_slot")
  endSlot        Int          @map("end_slot")
  isRaceSpecific Boolean      @default(false) @map("is_race_specific")
  raceDetails    String?      @map("race_details")
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boat      Boat?      @relation(fields: [boatId], references: [id])
  equipment Equipment? @relation(fields: [equipmentId], references: [id])
  oarSet    OarSet?    @relation(fields: [oarSetId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([date, boatId, startSlot])
  @@unique([date, equipmentId, startSlot])
  @@unique([date, oarSetId, startSlot])
  @@index([date])
  @@index([userId])
  @@index([boatId, date])
  @@map("bookings")
}

// ─── Booking Weeks ──────────────────────────────────────────────

model BookingWeek {
  id          String    @id @default(uuid())
  weekStart   DateTime  @unique @map("week_start") @db.Date
  opensAt     DateTime  @map("opens_at")
  closesAt    DateTime? @map("closes_at")
  pymbleNotes String?   @map("pymble_notes")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("booking_weeks")
}

// ─── Invitations ───────────────────────────────────────────────

model Invitation {
  id          String          @id @default(uuid())
  email       String
  token       String          @unique @default(uuid())
  role        UserRole        @default(member)
  memberType  MemberType      @default(recreational) @map("member_type")
  invitedBy   String          @map("invited_by")
  acceptedAt  DateTime?       @map("accepted_at")
  expiresAt   DateTime        @map("expires_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  inviter User @relation("Inviter", fields: [invitedBy], references: [id])

  @@index([email, acceptedAt])
  @@map("invitations")
}

// ─── Black Boat Applications ────────────────────────────────────

model BlackBoatApplication {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  status             ApplicationStatus @default(pending)
  regattaResults     String?           @map("regatta_results")
  ergTimes           String?           @map("erg_times")
  trainingRegime     String?           @map("training_regime")
  racingTargets      String?           @map("racing_targets")
  equipmentCareNotes String?           @map("equipment_care_notes")
  reviewedBy         String?           @map("reviewed_by")
  reviewedAt         DateTime?         @map("reviewed_at")
  createdAt          DateTime          @default(now()) @map("created_at")

  applicant User  @relation("Applicant", fields: [userId], references: [id])
  reviewer  User? @relation("Reviewer", fields: [reviewedBy], references: [id])

  @@index([userId, status])
  @@map("black_boat_applications")
}

// ─── Audit Log ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([targetType])
  @@index([createdAt])
  @@map("audit_logs")
}
